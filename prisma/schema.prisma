generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssignmentSource {
  MANUAL
  DISCORD
  SYSTEM
}

enum RevisionStatus {
  DRAFT
  PUBLISHED
  SUPERSEDED
}

enum MediaKind {
  IMAGE
  AUDIO
  VIDEO
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum StatusSource {
  ERLC
  DISCORD
  ROBLOX
  MANUAL
}

enum ServiceStatus {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
  MAINTENANCE
  UNKNOWN
}

model User {
  id                     String               @id @default(cuid())
  discordId              String?              @unique
  discordUsername        String?
  discordDisplayName     String?
  discordAvatarUrl       String?
  discordSyncedAt        DateTime?
  email                  String?              @unique
  name                   String
  avatar                 String?
  robloxName             String?
  robloxDisplayName      String?
  robloxAvatarUrl        String?
  robloxSyncedAt         DateTime?
  robloxUserId           String?              @unique
  registrationCompleted  Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  accounts               AuthAccount[]
  staffProfile           StaffProfile?
  ruleAcceptances        RuleAcceptance[]
  tickets                Ticket[]             @relation("TicketOwner")
  assignedTickets        Ticket[]             @relation("TicketAssignee")
  ticketMessages         TicketMessage[]
  authoredNews           NewsPost[]
  auditLogs              AuditLog[]
  roleAssignments        UserRoleAssignment[] @relation("UserRoleAssignments")
  grantedRoleAssignments UserRoleAssignment[] @relation("RoleAssignmentActor")
  ruleRevisions          RuleRevision[]       @relation("RuleRevisionEditor")
  newsRevisions          NewsRevision[]       @relation("NewsRevisionEditor")
  uploadedMedia          MediaAsset[]         @relation("MediaUploader")
  editedFaqItems         FaqItem[]             @relation("FaqItemEditor")
  statusUpdates          StatusUpdate[]        @relation("StatusUpdateAuthor")
}

model AuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  userId            String
  profile           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model StaffProfile {
  id           String      @id @default(cuid())
  userId       String?     @unique
  displayName  String
  title        String
  department   String
  bio          String?
  imageId      String?
  displayOrder Int         @default(0)
  visible      Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  image        MediaAsset? @relation("TeamProfileImage", fields: [imageId], references: [id], onDelete: SetNull)
}

model AccessRole {
  id              String                     @id @default(cuid())
  key             String                     @unique
  name            String                     @unique
  description     String?
  color           String                     @default("#d6aa4c")
  priority        Int                        @default(0)
  isSystem        Boolean                    @default(false)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  permissions     RolePermission[]
  assignments     UserRoleAssignment[]
  discordMappings DiscordRoleMapping[]
  ticketAccesses  RoleTicketCategoryAccess[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  description String?
  group       String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRoleAssignment {
  id           String           @id @default(cuid())
  userId       String
  roleId       String
  source       AssignmentSource
  sourceKey    String           @default("")
  assignedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role         AccessRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy   User?            @relation("RoleAssignmentActor", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, source, sourceKey])
  @@index([userId])
  @@index([roleId])
}

model DiscordRole {
  id            String               @id @default(cuid())
  guildId       String
  discordRoleId String
  name          String
  color         String?
  position      Int                  @default(0)
  managed       Boolean              @default(false)
  lastSyncedAt  DateTime             @default(now())
  mappings      DiscordRoleMapping[]

  @@unique([guildId, discordRoleId])
  @@index([guildId, position])
}

model DiscordRoleMapping {
  id            String      @id @default(cuid())
  discordRoleId String
  accessRoleId  String
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  discordRole   DiscordRole @relation(fields: [discordRoleId], references: [id], onDelete: Cascade)
  accessRole    AccessRole  @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)

  @@unique([discordRoleId, accessRoleId])
}

model DiscordMemberSnapshot {
  id           String   @id @default(cuid())
  guildId      String
  discordId    String
  username     String
  displayName  String?
  avatarUrl    String?
  roleIds      Json
  lastSyncedAt DateTime @default(now())

  @@unique([guildId, discordId])
  @@index([discordId])
}

model TicketCategory {
  id          String                     @id @default(cuid())
  key         String                     @unique
  label       String
  description String?
  enabled     Boolean                    @default(true)
  sortOrder   Int                        @default(0)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  tickets     Ticket[]
  roleAccess  RoleTicketCategoryAccess[]
}

model RoleTicketCategoryAccess {
  id         String         @id @default(cuid())
  roleId     String
  categoryId String
  canView    Boolean        @default(false)
  canReply   Boolean        @default(false)
  canAssign  Boolean        @default(false)
  canStatus  Boolean        @default(false)
  canDelete  Boolean        @default(false)
  role       AccessRole     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  category   TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([roleId, categoryId])
}

model Rule {
  id          String           @id @default(cuid())
  slug        String           @unique
  sourceKey   String?          @unique
  sourceUrl   String?
  category    String
  title       String
  order       Int              @default(0)
  version     Int              @default(0)
  published   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  acceptances RuleAcceptance[]
  revisions   RuleRevision[]
}

model RuleRevision {
  id          String              @id @default(cuid())
  ruleId      String
  status      RevisionStatus      @default(DRAFT)
  content     Json
  searchText  String
  editorId    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  publishedAt DateTime?
  rule        Rule                @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  editor      User?               @relation("RuleRevisionEditor", fields: [editorId], references: [id], onDelete: SetNull)
  media       RuleRevisionMedia[]

  @@index([ruleId, status, publishedAt])
}

model RuleRevisionMedia {
  id         String       @id @default(cuid())
  revisionId String
  mediaId    String
  sortOrder  Int          @default(0)
  caption    String?
  revision   RuleRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  media      MediaAsset   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([revisionId, mediaId])
}

model RuleAcceptance {
  id         String   @id @default(cuid())
  userId     String
  ruleId     String
  version    Int
  acceptedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule       Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId, version])
}

model NewsPost {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  excerpt     String
  coverLabel  String?
  published   Boolean        @default(false)
  publishedAt DateTime?
  editedAt    DateTime?
  authorId    String?
  thumbnailId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  thumbnail   MediaAsset?    @relation("NewsThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  revisions   NewsRevision[]
}

model NewsRevision {
  id          String              @id @default(cuid())
  newsPostId  String
  status      RevisionStatus      @default(DRAFT)
  content     Json
  searchText  String
  editorId    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  publishedAt DateTime?
  newsPost    NewsPost            @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  editor      User?               @relation("NewsRevisionEditor", fields: [editorId], references: [id], onDelete: SetNull)
  media       NewsRevisionMedia[]

  @@index([newsPostId, status, publishedAt])
}

model NewsRevisionMedia {
  id         String       @id @default(cuid())
  revisionId String
  mediaId    String
  sortOrder  Int          @default(0)
  caption    String?
  revision   NewsRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  media      MediaAsset   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([revisionId, mediaId])
}

model MediaAsset {
  id             String              @id @default(cuid())
  publicId       String              @unique
  secureUrl      String
  resourceType   String
  kind           MediaKind
  mimeType       String
  originalName   String
  bytes          Int
  width          Int?
  height         Int?
  duration       Float?
  createdById    String?
  createdAt      DateTime            @default(now())
  createdBy      User?               @relation("MediaUploader", fields: [createdById], references: [id], onDelete: SetNull)
  ruleRevisions  RuleRevisionMedia[]
  newsRevisions  NewsRevisionMedia[]
  newsThumbnails NewsPost[]          @relation("NewsThumbnail")
  teamImages     StaffProfile[]       @relation("TeamProfileImage")
}

model Ticket {
  id         String          @id @default(cuid())
  number     Int             @unique
  subject    String
  categoryId String
  priority   String          @default("NORMAL")
  status     TicketStatus    @default(OPEN)
  userId     String
  assigneeId String?
  ownerArchivedAt DateTime?
  ownerHiddenAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   TicketCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user       User            @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignee   User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages   TicketMessage[]

  @@index([categoryId, status, updatedAt])
  @@index([userId, ownerHiddenAt, ownerArchivedAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([actorId, createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id          String   @id @default(cuid())
  question    String
  answer      String
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  editorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  editor      User?    @relation("FaqItemEditor", fields: [editorId], references: [id], onDelete: SetNull)

  @@index([visible, sortOrder])
}

model StatusService {
  id            String        @id @default(cuid())
  key           String        @unique
  name          String
  description   String?
  source        StatusSource
  enabled       Boolean       @default(true)
  sortOrder     Int           @default(0)
  manualStatus  ServiceStatus @default(OPERATIONAL)
  lastStatus    ServiceStatus @default(UNKNOWN)
  lastMessage   String?
  lastCheckedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  updates       StatusUpdate[]

  @@index([enabled, sortOrder])
}

model StatusUpdate {
  id        String        @id @default(cuid())
  serviceId String
  status    ServiceStatus
  message   String?
  public    Boolean       @default(true)
  authorId  String?
  createdAt DateTime      @default(now())
  service   StatusService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  author    User?         @relation("StatusUpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([serviceId, createdAt])
  @@index([public, createdAt])
}

model BotRecord {
  id             String    @id @default(cuid())
  namespace      String
  key            String
  discordGuildId String?
  data           Json
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([namespace, key])
  @@index([namespace])
  @@index([discordGuildId])
}

model BotEvent {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  type           String
  discordGuildId String?
  source         String   @default("discord-bot")
  data           Json
  occurredAt     DateTime
  createdAt      DateTime @default(now())

  @@index([type, occurredAt])
}

model BotSyncReceipt {
  id         String   @id @default(cuid())
  externalId String   @unique
  kind       String
  createdAt  DateTime @default(now())
}
